# Copy to `.env` at this repo root (same folder as `package.json`).
# Values here are loaded automatically when the API starts (`python-dotenv`).

# --- Database ---
# Leave unset to use local SQLite (`data/db.sqlite`).
# Supabase: Project Settings → Database → URI (include sslmode=require if needed).
# DATABASE_URL=postgresql://postgres.[ref]:YOUR_PASSWORD@aws-0-....pooler.supabase.com:5432/postgres?sslmode=require
