# Copy to `.env` at this repo root (same folder as `package.json`).
# Values here are loaded automatically when the API starts (`python-dotenv`).

# --- Database ---
# Leave unset to use local SQLite (`data/db.sqlite`).
#
# Supabase: Project Settings → Database → Connection string → URI.
# - For Render / hosts without IPv6: use Session pooler (port 6543), NOT Direct (db.*:5432).
# - Include sslmode=require if the template does not.
# DATABASE_URL=postgresql://postgres.[ref]:YOUR_PASSWORD@aws-0-....pooler.supabase.com:6543/postgres?sslmode=require

# --- Supabase Storage (slide PNGs; optional) ---
# When both are set, slide images are uploaded to a public bucket instead of only on disk.
# Use the Project URL (https://xxx.supabase.co) and the service_role key from API Settings.
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Optional bucket id (default bella-note-slides; create in Supabase if missing):
# SUPABASE_STORAGE_BUCKET=bella-note-slides

# --- Render / large PDFs ---
# Lower = faster uploads, less RAM (default 110 when RENDER=true, else 150).
# SLIDE_RENDER_DPI=100
